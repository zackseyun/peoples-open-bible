{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zackseyun/peoples-open-bible/schema/verse.schema.json",
  "title": "People's Open Bible per-verse record",
  "description": "Full provenance record for a single verse. Every verse in the translation is stored as a YAML file conforming to this schema.",
  "type": "object",
  "required": ["id", "reference", "source", "translation", "ai_draft"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Canonical verse identifier, e.g., MAT.1.1, PHP.1.6, or deuterocanonical codes like TOB.1.1, 4MA.18.24.",
      "pattern": "^[A-Z0-9]{2,5}\\.\\d+\\.\\d+$"
    },
    "reference": {
      "type": "string",
      "description": "Human-readable reference, e.g., 'Matthew 1:1'"
    },
    "source": {
      "type": "object",
      "required": ["edition", "text"],
      "properties": {
        "edition": {
          "type": "string",
          "enum": [
            "SBLGNT",
            "WLC",
            "UHB",
            "Rahlfs-LXX",
            "lxx-swete-1909",
            "sefaria-ben-sira-kahana",
            "neubauer-tobit-1878",
            "hebrew-sirach-schechter-1899",
            "aramaic-tobit-qumran",
            "charles-1906-enoch"
          ],
          "description": "Source edition identifier. SBLGNT = Greek NT; WLC/UHB = Masoretic Hebrew; lxx-swete-1909 = Swete's Septuagint for deuterocanonical books; sefaria-ben-sira-kahana = Kahana / Sefaria Hebrew Sirach; neubauer-tobit-1878 = Neubauer's Hebrew Tobit; hebrew-sirach-schechter-1899 = Cairo Genizah MSS A+B for Hebrew Sirach; aramaic-tobit-qumran = Qumran Aramaic Tobit fragments; charles-1906-enoch = Charles 1906 Ethiopic Enoch OCR base text."
        },
        "text": {
          "type": "string",
          "description": "The verbatim source-language text"
        },
        "language": {
          "type": "string",
          "description": "Human-readable language label for the primary source witness"
        },
        "note": {
          "type": "string",
          "description": "Optional note about how this witness should be used"
        },
        "numbering_note": {
          "type": "string",
          "description": "Optional note when the source's internal chapter/verse numbering differs from common reader editions"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Confidence level for the source-text reading when preserved from the corpus layer"
        },
        "validation": {
          "type": "string",
          "description": "Corpus-layer validation status carried forward from the source preparation stage"
        },
        "pages": {
          "type": "array",
          "description": "Source scan pages associated with this verse when known",
          "items": { "type": "integer" }
        },
        "parallel_sources": {
          "type": "array",
          "description": "Additional Zone 1 witnesses used at draft time alongside the primary source",
          "items": {
            "type": "object",
            "required": ["edition", "text"],
            "properties": {
              "edition": {
                "type": "string",
                "enum": [
                  "SBLGNT",
                  "WLC",
                  "UHB",
                  "Rahlfs-LXX",
                  "lxx-swete-1909",
                  "sefaria-ben-sira-kahana",
                  "neubauer-tobit-1878",
                  "hebrew-sirach-schechter-1899",
                  "aramaic-tobit-qumran"
                ]
              },
              "text": { "type": "string" },
              "kind": { "type": "string" },
              "note": { "type": "string" },
              "reference": { "type": "string" }
            }
          }
        },
        "apparatus": {
          "type": "array",
          "description": "Notes on variant readings consulted",
          "items": {
            "type": "object",
            "properties": {
              "witness": { "type": "string" },
              "reading": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "translation": {
      "type": "object",
      "required": ["text", "philosophy"],
      "properties": {
        "text": {
          "type": "string",
          "description": "The final English rendering published to readers"
        },
        "philosophy": {
          "type": "string",
          "enum": ["formal", "dynamic", "optimal-equivalence"],
          "description": "Translation approach applied to this verse"
        },
        "footnotes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["marker", "text"],
            "properties": {
              "marker": { "type": "string", "description": "In-text marker, e.g., 'a', 'b'" },
              "text": { "type": "string" },
              "reason": {
                "type": "string",
                "enum": [
                  "alternative_reading",
                  "lexical_alternative",
                  "textual_variant",
                  "cultural_note",
                  "cross_reference"
                ]
              }
            }
          }
        }
      }
    },
    "lexical_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_word", "chosen", "rationale"],
        "properties": {
          "source_word": {
            "type": "string",
            "description": "The Greek or Hebrew word being rendered"
          },
          "chosen": {
            "type": "string",
            "description": "The English gloss chosen"
          },
          "alternatives": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lexicon": {
            "type": "string",
            "description": "Lexicon referenced, e.g., BDAG, HALOT, LSJ, Louw-Nida"
          },
          "entry": {
            "type": "string",
            "description": "Entry number or identifier within the lexicon"
          },
          "rationale": {
            "type": "string",
            "description": "Why this gloss was chosen over alternatives"
          }
        }
      }
    },
    "theological_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "chosen_reading", "rationale"],
        "properties": {
          "issue": {
            "type": "string",
            "description": "Short name of the contested question"
          },
          "chosen_reading": { "type": "string" },
          "alternative_readings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": "string" },
          "doctrine_reference": {
            "type": "string",
            "description": "Link to the relevant section of DOCTRINE.md"
          }
        }
      }
    },
    "ai_draft": {
      "type": "object",
      "required": ["model_id", "model_version", "prompt_id", "prompt_sha256", "timestamp", "output_hash"],
      "properties": {
        "model_id": { "type": "string" },
        "model_version": { "type": "string" },
        "prompt_id": { "type": "string" },
        "prompt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "timestamp": { "type": "string", "format": "date-time" },
        "output_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "raw_output_ref": {
          "type": "string",
          "description": "Git LFS or storage reference to the raw model output (optional)"
        },
        "zone1_sources_at_draft": {
          "type": "array",
          "items": { "type": "string" }
        },
        "zone2_consults_known": {
          "type": "array",
          "items": { "type": "string" }
        },
        "revision_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reason", "trigger"],
            "properties": {
              "reason": { "type": "string" },
              "trigger": { "type": "string" }
            }
          }
        }
      }
    },
    "cross_check": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["high_agreement", "moderate_agreement", "needs_review"],
          "description": "Bucket derived from the selected agreement score."
        },
        "agreement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Website-compatible alias for agreement_score."
        },
        "models": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strategies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "agreement_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "agreement_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "agreement_max": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verdict": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string"
        },
        "reviewer_model": {
          "type": "string"
        },
        "strategy": {
          "type": "string"
        },
        "pass_count": {
          "type": "integer",
          "minimum": 1
        },
        "passes_with_issues": {
          "type": "integer",
          "minimum": 0
        },
        "verdict_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "source_review": {
          "type": "string",
          "description": "Local state/reviews path for the selected review pass."
        },
        "divergences_resolved_at": {
          "type": "string",
          "description": "GitHub issue number or URL where divergences were reconciled"
        }
      }
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of this verse record.",
      "enum": ["draft"]
    },
    "discussion": {
      "type": "string",
      "description": "URL to GitHub issue(s) discussing this verse",
      "format": "uri"
    }
  }
}
